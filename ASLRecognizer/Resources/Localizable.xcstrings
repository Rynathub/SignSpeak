    },
    "The recognized text will appear instantly below the camera. Use the speak button to hear it aloud or save to history." : {
      "localizations" : {
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Розпізнаний текст миттєво з'явиться під камерою."
          }
        }
      }
    },
    "This is a demonstration app showcasing sign language recognition technology. The gesture library is limited and results may vary. For comprehensive communication, please consult with professional sign language interpreters." : {
      "localizations" : {
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Це демонстраційний додаток для розпізнавання жестів. Бібліотека жестів обмежена, і результати можуть відрізнятися."
          }
        }
      }
    },
